# ── ClawBot Mission Control — Environment Variables ──────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── ElevenLabs (optional) ────────────────────────────────────
# If not set, the system falls back to the browser's built-in TTS.
VITE_ELEVENLABS_API_KEY=sk_your-key-here
VITE_ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── GitHub Pages deployment ───────────────────────────────────
# Set to your GitHub repository name (the part after github.com/username/)
# Used to compute the correct base URL for the app.
VITE_REPO_NAME=clawbot-mission-control
